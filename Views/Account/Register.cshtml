@{
    ViewData["Title"] = "Register";
}

<style>
    .theme-card { border: none; border-radius: 1rem; background-color: #ffffff; box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15); }
    .theme-title { color: #2c3e50; font-family: 'Montserrat', sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
    .divider-custom { margin: 1rem 0 1.5rem; display: flex; justify-content: center; align-items: center; }
    .divider-custom-line { width: 100%; max-width: 4rem; height: 0.25rem; background-color: #2c3e50; border-radius: 1rem; }
    .divider-custom-icon { color: #2c3e50; font-size: 1.25rem; margin: 0 1rem; }
    .theme-input { border-radius: 0.5rem; border: 2px solid #ced4da; padding: 0.75rem 1rem; transition: all 0.3s ease; }
    .theme-input:focus { border-color: #1abc9c; box-shadow: 0 0 0 0.25rem rgba(26, 188, 156, 0.25); }
    .theme-label { color: #2c3e50; font-weight: 700; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 0.5rem; }
    .btn-theme { background-color: #1abc9c; border: 2px solid #1abc9c; color: white; font-weight: 700; text-transform: uppercase; padding: 0.75rem 1.5rem; border-radius: 0.5rem; transition: all 0.3s ease; }
    .btn-theme:hover { background-color: #159b80; border-color: #159b80; color: white; }
    .text-theme-link { color: #1abc9c; font-weight: bold; }
    .text-theme-link:hover { color: #159b80; }
</style>

<div class="container min-vh-100 d-flex flex-column justify-content-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card theme-card p-4">
                <div class="card-body">
                    <h2 class="text-center theme-title mb-0">Register</h2>
                    <div class="divider-custom">
                        <div class="divider-custom-line"></div>
                        <div class="divider-custom-icon">★</div>
                        <div class="divider-custom-line"></div>
                    </div>

                    <form asp-controller="Account" asp-action="Register" method="post" id="registerForm">
                        
                        <div class="mb-3">
                            <label class="form-label theme-label">Full Name</label>
                            <input type="text" name="FullName" class="form-control theme-input" placeholder="Enter your full name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label theme-label">Email Address</label>
                            <input type="email" name="Email" class="form-control theme-input" placeholder="example@domain.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label theme-label">Password</label>
                            <input type="password" name="Password" class="form-control theme-input" placeholder="Create a password" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label theme-label">Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control theme-input" placeholder="Confirm your password" required />
                        </div>

                        <button type="submit" class="btn btn-theme w-100">Sign Up</button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted">Already have an account? 
                            <a asp-controller="Account" asp-action="Login" class="text-theme-link text-decoration-none">Sign In</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $('#registerForm').on('submit', function (e) {
            e.preventDefault();

            $.ajax({
                url: '@Url.Action("Register", "Account")',
                type: 'POST',
                data: $(this).serialize(),
                success: function (response) {
                    if (response.success) {
                        // 1. Confirmation alert showing the details
                        var confirmMessage = "Please review your registration details:\n\n" +
                                             "Full Name: " + response.userData.fullName + "\n" +
                                             "Email: " + response.userData.email + "\n" +
                                             "Password: " + response.userData.password + "\n\n" +
                                             "Are you sure you want to register?";

                        var isConfirmed = confirm(confirmMessage);

                        if (isConfirmed) {
                            // 2. Success alert showing the details
                            var successMessage = "Sign Up Successfully!\n\n" +
                                                 "Full Name: " + response.userData.fullName + "\n" +
                                                 "Email: " + response.userData.email + "\n" +
                                                 "Password: " + response.userData.password;

                            alert(successMessage);

                            // 3. Reset the form and remain on the registration page
                            $('#registerForm')[0].reset();
                        }
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("An error occurred during registration.");
                }
            });
        });
    });
</script>