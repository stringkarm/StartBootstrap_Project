@{
    ViewData["Title"] = "Register";
}

<style>
    /* Signature Freelancer Theme Styles */
    .theme-card {
        border: none;
        border-radius: 1rem;
        background-color: #ffffff;
        box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.15);
    }

    .theme-title {
        color: #2c3e50;
        font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Theme Star Divider */
    .divider-custom {
        margin: 1rem 0 1.5rem;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .divider-custom-line {
        width: 100%;
        max-width: 4rem;
        height: 0.25rem;
        background-color: #2c3e50;
        border-radius: 1rem;
    }

    .divider-custom-icon {
        color: #2c3e50;
        font-size: 1.25rem;
        margin: 0 1rem;
    }

    /* Custom Inputs */
    .theme-input {
        border-radius: 0.5rem;
        border: 2px solid #ced4da;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

        .theme-input:focus {
            border-color: #1abc9c;
            box-shadow: 0 0 0 0.25rem rgba(26, 188, 156, 0.25);
        }

    .theme-label {
        color: #2c3e50;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Theme Button */
    .btn-theme {
        background-color: #1abc9c;
        border: 2px solid #1abc9c;
        color: white;
        font-weight: 700;
        text-transform: uppercase;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .btn-theme:hover, .btn-theme:focus {
            background-color: #159b80;
            border-color: #159b80;
            color: white;
        }

    .text-theme-link {
        color: #1abc9c;
        font-weight: bold;
        transition: color 0.2s ease;
    }

        .text-theme-link:hover {
            color: #159b80;
        }
</style>

<div class="container mt-4 py-4">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card theme-card p-3">
                <div class="card-body">

                    <h2 class="theme-title text-center mb-1">Register</h2>
                    <div class="divider-custom">
                        <div class="divider-custom-line"></div>
                        <div class="divider-custom-icon">★</div>
                        <div class="divider-custom-line"></div>
                    </div>

                    <form asp-controller="Account" asp-action="Register" method="post">

                        <div class="mb-3">
                            <label class="form-label theme-label">Full Name</label>
                            <input type="text" name="FullName" class="form-control theme-input" placeholder="Enter your full name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label theme-label">Email Address</label>
                            <input type="email" name="Email" class="form-control theme-input" placeholder="example@domain.com" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label theme-label">Password</label>
                            <input type="password" name="Password" class="form-control theme-input" placeholder="Create a password" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label theme-label">Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control theme-input" placeholder="Confirm your password" required />
                        </div>

                        <button type="submit" class="btn btn-theme w-100 mt-2 mb-3">Sign Up</button>

                        <div class="text-center">
                            <p class="mb-0 text-muted">
                                Already have an account?
                                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-theme-link">Sign In</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>